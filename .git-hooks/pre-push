#!/bin/bash

set -e

echo "🔍 [pre-push] Running PHP-CS-Fixer check..."
docker compose exec -T php vendor/bin/php-cs-fixer fix --dry-run --diff --allow-risky=yes
if [ $? -ne 0 ]; then
  echo "❌ PHP-CS-Fixer failed. Run 'make cs-fix' then commit again."
  exit 1
fi

echo "🔍 [pre-push] Running PHPStan..."
docker compose exec -T php vendor/bin/phpstan analyse --memory-limit=256M
if [ $? -ne 0 ]; then
  echo "❌ PHPStan failed. Fix errors before pushing."
  exit 1
fi

echo "✅ [pre-push] All checks passed."
exit 0
